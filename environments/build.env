# Build-time env — the ONLY env file used while building the Docker image
# (`cp environments/build.env .env && npm run build`). Everything here is baked
# into the bundle and must be identical for all contours. Per-contour runtime
# values live in <contour>.env and are injected by compose at deploy time.

NUXT_SSR=1

NUXT_BASE_TITLE="Nuxt Core Template"
NUXT_PUBLIC_APP_DESCRIPTION="Nuxt Core Template"
NUXT_PUBLIC_APP_AUTHOR="yesfedor"
NUXT_PUBLIC_APP_THEME_COLOR="white"
